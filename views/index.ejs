<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link href="/css/output.css" rel="stylesheet" />
    <title>Ratio</title>
  </head>
  <body>
    <div class="flex flex-col border border-black rounded-lg w-80">
      <div>
        <h3 class="font-mono">Welcome to Ratio!</h3>
      </div>
      <h4>Log back in!</h4>
      <div>
        <p>Enter your username</p>
        <input
          type="text"
          placeholder="Username"
          class="border-emerald-600 rounded-lg"
        />
      </div>
      <div>
        <p>Enter your password</p>
        <input
          type="text"
          placeholder="Password"
          class="border-emerald-600 rounded-lg"
        />
      </div>
    </div>
  </body>
</html>
